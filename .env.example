APP_NAME=KidRead Backend
DEBUG=true

# PostgreSQL is the thesis-aligned main database.
DATABASE_URL=postgresql+psycopg://kidread:kidread123@localhost:5432/kidread

# Redis: cache, locks, task state, and optional queue.
ENABLE_REDIS=true
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_NAME=kidread:jobs
ENABLE_ASYNC_TASKS=false

# Qdrant: story chunk vector retrieval.
ENABLE_QDRANT=true
ENABLE_RAG=true
ENABLE_FAST_CONTEXT=true
VECTOR_BACKEND=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=story_chunks
QDRANT_VECTOR_SIZE=0

# LLM service, OpenAI-compatible endpoint.
LLM_API_KEY=replace-with-your-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-3.5-flash

# Embedding service for Qdrant.
EMBEDDING_API_KEY=replace-with-your-key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

# TTS and ASR.
ENABLE_TTS_MANIFEST=true
ENABLE_PERSISTENT_ASR=false
HTTP_PUBLIC_BASE_URL=http://127.0.0.1:8000
TTS_OUTPUT_DIR=./static/tts
XF_APP_ID=
XF_API_KEY=
XF_API_SECRET=
XF_HOST=
XF_PATH=
XF_LANGUAGE=
XF_DOMAIN=
XF_ACCENT=
XF_VAD_EOS=
XF_AUDIO_FORMAT=
XF_AUDIO_ENCODING=

# WeChat login. In local debug, dev_openid fallback is allowed.
WX_APP_ID=
WX_APP_SECRET=
TOKEN_SECRET=replace-with-a-random-secret
ACCESS_TOKEN_EXPIRE_DAYS=30
